{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qcast",
  "version": "0.1.0",
  "identifier": "app.qcast.desktop",
  "build": {
    "frontendDist": "../crates/qcast-sender/web-client/dist",
    "beforeBuildCommand": "cd ../crates/qcast-sender/web-client && npm install && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Qcast",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "skipTaskbar": false
      }
    ],
    "trayIcon": {
      "id": "qcast-tray",
      "iconPath": "icons/icon.png",
      "tooltip": "Qcast",
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "gst-runtime/bin": "bin",
      "gst-runtime/lib/gstreamer-1.0": "lib/gstreamer-1.0",
      "gst-runtime/libexec/gstreamer-1.0/gst-plugin-scanner.exe": "libexec/gstreamer-1.0/gst-plugin-scanner.exe"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer-hooks.nsh"
      },
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    }
  }
}
